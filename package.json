{
	"name": "@requify/requify-design-system",
	"version": "1.9.2",
	"description": "A professional, customizable design system for Requify built with Svelte 5, Tailwind CSS, and bits-ui",
	"keywords": [
		"svelte",
		"sveltekit",
		"design-system",
		"ui-components",
		"tailwindcss",
		"bits-ui"
	],
	"homepage": "https://github.com/requify-app/requify-design-system#readme",
	"bugs": {
		"url": "https://github.com/requify-app/requify-design-system/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/requify-app/requify-design-system.git"
	},
	"license": "MIT",
	"author": "paul@requify.app",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./theme.css": "./src/lib/styles/theme.css"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*",
		"src/lib",
		"!src/lib/**/*.test.*",
		"!src/lib/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"scripts": {
		"dev": "vite dev",
		"build:lib": "svelte-package",
		"build:site": "vite build",
		"preview": "vite preview",
		"svelte-sync": "svelte-kit sync",
		"check": "svelte-kit sync && svelte-check --threshold error --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --threshold error --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --experimental-cli --write .",
		"format-check": "prettier --experimental-cli --check .",
		"prepublishOnly": "pnpm run build:lib",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:setup": "playwright install chromium"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.23.0",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"@vitest/browser": "^4.1.9",
		"@vitest/browser-playwright": "^4.1.9",
		"playwright": "^1.61.1",
		"prettier": "3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"vite": "^8.1.3",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.2.0"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"packageManager": "pnpm@11.1.3"
}
